pipeline {
    agent any
    environment {
        SERVICES = "circleguard-auth-service circleguard-identity-service circleguard-form-service circleguard-promotion-service circleguard-notification-service circleguard-gateway-service"
        KUBE_NAMESPACE = "circleguard-master"
    }
    stages {
        stage('Checkout') { steps { checkout scm } }
        stage('Build Gradle') { steps { sh "./gradlew bootJar --no-daemon" } }
        stage('Unit & Integration Tests') { 
            steps { 
                sh "./gradlew test integrationTest --no-daemon" 
            } 
        }
        stage('Build Docker Images') {
            steps {
                script {
                    def serviceList = SERVICES.split(' ')
                    for (service in serviceList) {
                        sh "docker build -f services/${service}/Dockerfile -t ${service}:local ."
                    }
                }
            }
        }
        stage('Deploy Kubernetes Master') {
            steps {
                sh "kubectl apply -f k8s/namespace.yaml --insecure-skip-tls-verify"
                sh "kubectl apply -n ${KUBE_NAMESPACE} -f k8s/config.yaml --insecure-skip-tls-verify"
                sh "kubectl apply -n ${KUBE_NAMESPACE} -f k8s/infrastructure.yaml --insecure-skip-tls-verify"
                sh "kubectl apply -n ${KUBE_NAMESPACE} -f k8s/services.yaml --insecure-skip-tls-verify"
                sh "kubectl get pods -n ${KUBE_NAMESPACE} --insecure-skip-tls-verify"
                sh "kubectl get svc -n ${KUBE_NAMESPACE} --insecure-skip-tls-verify"
                sh "kubectl rollout status deployment/circleguard-auth-service -n ${KUBE_NAMESPACE} --timeout=120s --insecure-skip-tls-verify || true"
            }
        }
        stage('Smoke Test') {
            steps {
                sh "kubectl get pods -n ${KUBE_NAMESPACE} --insecure-skip-tls-verify"
                sh "echo 'MASTER deployment verificado correctamente'"
            }
        }
        stage('Generate Release Notes') {
            steps {
                sh """
                    echo '# Release Notes' > release-notes.md
                    echo '' >> release-notes.md
                    echo '**Build:** ${BUILD_NUMBER}' >> release-notes.md
                    echo '**Fecha:** '\$(date) >> release-notes.md
                    echo '**Namespace:** ${KUBE_NAMESPACE}' >> release-notes.md
                    echo '' >> release-notes.md
                    echo '## Cambios incluidos' >> release-notes.md
                    git log --oneline --no-merges -20 >> release-notes.md
                """
                archiveArtifacts artifacts: 'release-notes.md', fingerprint: true
            }
        }
    }
}
